<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- 10.0.2.2 is the default IP address pointing to the host machine loopback for Android Emulator -->
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Include standard local network segments for development with physical devices -->
        <domain includeSubdomains="true">192.168.1.1</domain>
        <domain includeSubdomains="true">192.168.1.2</domain>
        <domain includeSubdomains="true">192.168.1.3</domain>
        <domain includeSubdomains="true">192.168.1.4</domain>
        <domain includeSubdomains="true">192.168.1.5</domain>
        <domain includeSubdomains="true">192.168.1.6</domain>
        <domain includeSubdomains="true">192.168.1.7</domain>
        <domain includeSubdomains="true">192.168.1.8</domain>
        <domain includeSubdomains="true">192.168.1.9</domain>
        <domain includeSubdomains="true">192.168.1.10</domain>
        <domain includeSubdomains="true">192.168.1.11</domain>
        <domain includeSubdomains="true">192.168.1.12</domain>
        <domain includeSubdomains="true">192.168.1.13</domain>
        <domain includeSubdomains="true">192.168.1.14</domain>
        <domain includeSubdomains="true">192.168.1.15</domain>
        <domain includeSubdomains="true">192.168.1.16</domain>
        <domain includeSubdomains="true">192.168.1.17</domain>
        <domain includeSubdomains="true">192.168.1.18</domain>
        <domain includeSubdomains="true">192.168.1.19</domain>
        <domain includeSubdomains="true">192.168.1.20</domain>
        <!-- Or allow all cleartext traffic in development -->
        <domain includeSubdomains="true">10.110.11.13</domain>
    </domain-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>

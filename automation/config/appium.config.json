{
  "appium": {
    "host": "127.0.0.1",
    "port": 4723,
    "timeout": 120
  },
  "capabilities": {
    "platformName": "Android",
    "automationName": "UiAutomator2",
    "deviceName": "E2E_Emulator",
    "platformVersion": "14",
    "appPackage": "com.imageauth.verifier",
    "appActivity": "com.imageauth.verifier.MainActivity",
    "noReset": false,
    "fullReset": false,
    "autoGrantPermissions": true,
